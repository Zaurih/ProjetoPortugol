programa {
  funcao inicio() {
    inteiro menor, idade
    escreva ("informe a sua idade:")
   leia(idade)

    se (idade < 18) {
      escreva ("Você é um menor de idade. Fala aí menor!!! ")
    }senao{
      escreva("Você e maior de idade.")
    }

    escreva("\n") // comando para quebrar a linha
  }
}
